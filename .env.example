# Resend API
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# Optional: override the "from" address (must be a verified Resend domain in production)
# Default: onboarding@resend.dev (Resend's shared sandbox; works for testing)
RESEND_FROM="Stratos Web <hello@your-verified-domain.com>"

# Optional: override the recipient — defaults to site.contact.email (stratosiha@gmail.com)
CONTACT_TO=stratosiha@gmail.com

# --- Admin panel (/admin) ---
# Shared password for the admin login. Use a long, random value.
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie (HMAC). 32+ random chars.
# Generate with: openssl rand -base64 32
SESSION_SECRET=
# Fine-grained GitHub token with Contents: Read and write on the site repo only.
GITHUB_TOKEN=
# Target repo (owner/name) the admin panel commits content to.
GITHUB_REPO=iWeslax83/iha-website
# Branch the admin panel commits to. Use a scratch branch locally to avoid touching main.
GITHUB_BRANCH=main
